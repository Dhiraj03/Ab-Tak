{
  "name": "ab-tak",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["ui", "backend"],
  "scripts": {
    "dev:ui": "npm run dev -w ui",
    "dev:backend": "npm run dev -w backend",
    "dev": "concurrently -n backend,ui -c yellow,cyan \"npm:dev:backend\" \"npm:dev:ui\"",
    "build:backend": "npm run build -w backend",
    "build:ui": "npm run build -w ui",
    "build": "npm run build:backend && npm run build:ui",
    "deploy:backend": "npm run deploy -w backend",
    "deploy:ui": "npm run deploy -w ui",
    "deploy": "npm run deploy:backend && npm run deploy:ui"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
